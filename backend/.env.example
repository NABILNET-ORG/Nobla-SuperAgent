# Nobla Agent Backend Configuration
# Copy this file to .env and fill in your values

# LLM Provider API Keys (leave empty to disable)
GEMINI_API_KEY=
GROQ_API_KEY=

# Database (defaults work with docker-compose)
# DATABASE_URL=postgresql+asyncpg://nobla:nobla@localhost:5432/nobla
# REDIS_URL=redis://localhost:6379/0

# REQUIRED: Generate a random secret key before running in production
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
